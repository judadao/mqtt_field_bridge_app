&pinctrl {
	spim3_w5500: spim3_w5500 {
		group1 {
			pinmux = <SPIM3_MISO_GPIO19>,
				 <SPIM3_SCLK_GPIO18>;
		};

		group2 {
			pinmux = <SPIM3_MOSI_GPIO23>;
			output-low;
		};
	};
};

&spi3 {
	status = "okay";
	pinctrl-0 = <&spim3_w5500>;
	cs-gpios = <&gpio0 5 GPIO_ACTIVE_LOW>;

	eth_w5500: eth-w5500@0 {
		compatible = "wiznet,w5500";
		reg = <0>;
		spi-max-frequency = <1000000>;
		local-mac-address = [02 00 00 12 34 56];
	};
};
