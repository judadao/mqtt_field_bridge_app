{
  "deps": {
    "mqtt_min_broker": {
      "repo": "git@github.com:judadao/zephy_min_mqtt_broker.git",
      "local": "../mqtt_min_broker",
      "version": "mqtt-v0.1.18",
      "path": "deps/mqtt_min_broker"
    },
    "dephy": {
      "repo": "git@github.com:judadao/dephy.git",
      "local": "../dephy",
      "version": "dephy-v0.1.8",
      "path": "deps/dephy",
      "profile": "esp32",
      "module_path": "deps/dephy/boards/esp32",
      "tag_pattern": "dephy-v*"
    },
    "dephy_industrial_io": {
      "repo": "git@github.com:judadao/dephy_industrial_io.git",
      "local": "../dephy_industrial_io",
      "version": "d26d985",
      "path": "deps/dephy_industrial_io",
      "module_path": "deps/dephy_industrial_io"
    },
    "dephy_eth": {
      "repo": "git@github.com:judadao/dephy_eth.git",
      "local": "../dephy_eth",
      "version": "dephy-eth-v0.1.1",
      "path": "deps/dephy_eth",
      "module_path": "deps/dephy_eth",
      "tag_pattern": "dephy-eth-v*"
    },
    "dephy_testkit": {
      "repo": "git@github.com:judadao/dephy_testkit.git",
      "local": "../dephy_testkit",
      "version": "e0b70d9",
      "path": "deps/dephy_testkit"
    }
  },
  "zephyr": {
    "min_version": "v3.5.0",
    "manager": "dephy"
  },
  "build": {
    "board": "esp32_devkitc/esp32/procpu",
    "dephy_workspace": "deps/dephy/zephyrproject",
    "extra_conf_files": [
      "deps/dephy/boards/esp32/conf/product_slim.conf"
    ]
  }
}
